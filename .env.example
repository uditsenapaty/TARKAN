# Copy to .env.local (git-ignored) and fill in. Only HF_TOKEN is required for the default path.

# Hugging Face token (read access; needed to download models, and to accept gated models).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — NOT used by the default open-source pipeline.
# OPENAI_API_KEY=          # only if you ever benchmark against closed APIs (not part of TARKAN)
# WANDB_API_KEY=           # only if you enable Weights & Biases logging
